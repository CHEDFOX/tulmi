<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#15151b">

    <!--
      Top bar. Mirrors the iOS Wispr-style top row: a right-aligned tone pill
      that opens a popup with persistent tones (Casual/Neutral/Formal), an
      Emoji On/Off toggle, and one-shot commands (Shorter/Longer/Bullet points).
      Wired in TulmiKeyboardService.onCreateInputView.
    -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|end"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/tone_pill"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:text="Neutral"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#000000"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textColor="#cfcfe0"
        android:textSize="13sp"
        android:visibility="gone" />

    <android.inputmethodservice.KeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#15151b"
        android:keyTextColor="#ffffff"
        android:keyBackground="@android:drawable/btn_default_small" />
</LinearLayout>
