# =====================================================================
# Flow — environment variables
# Copy this file to `.env` (in the repo root AND/OR backend/) and fill in
# real values. NEVER commit the real .env. Secrets live ONLY in env vars.
# =====================================================================

# --- Groq (Speech-to-Text / Whisper) ---
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Whisper model on Groq. whisper-large-v3-turbo is fast + multilingual
# (good for Hindi/Hinglish). Alternative: whisper-large-v3 (more accurate).
GROQ_STT_MODEL=whisper-large-v3-turbo

# --- OpenRouter (cleanup LLM) ---
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default cleanup model. Swap this ONE line to change models — no code edits.
# Default: fast + cheap + strong multilingual.
CLEANUP_MODEL=anthropic/claude-haiku-4.5

# Optional headers OpenRouter uses for attribution/ranking (safe to leave).
OPENROUTER_APP_URL=https://flow.local
OPENROUTER_APP_NAME=Flow

# --- Supabase (auth + usage metering) ---
# Project settings → API. URL is public; the SERVICE ROLE key is SECRET
# (server-side only, never ship it to the Android app).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# The anon/public key is what the Android app uses to sign users in.
SUPABASE_ANON_KEY=

# --- Server ---
PORT=8080
HOST=0.0.0.0

# Set to "true" to skip Supabase auth + metering during local pipeline
# testing (so test-pipeline.ts runs with only Groq + OpenRouter keys).
DEV_SKIP_AUTH=true
